// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER MODEL ──────────────────────────────────────────────────
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  phone         String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)
  name          String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Profile relations
  clientProfile ClientProfile?
  coupleProfile CoupleProfile?
  creatorProfile CreatorProfile?
  adminProfile  AdminProfile?
  
  // Relations
  bookings      Booking[]
  creatorBookings Booking[] @relation("CreatorBookings")
  videos        Video[]
  posts         Post[]
  comments      Comment[]
  supports      Support[]
  payments      Payment[]
  notifications Notification[]
  videoPurchases VideoPurchase[]
}

// ─── PROFILES ─────────────────────────────────────────────────────
model ClientProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address     String?
  preferences String?
}

model CoupleProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groomName     String
  brideName     String
  weddingDate   DateTime?
  location      String?
  district      String?
  story         String?
  coverImage    String?
  profileImage  String?
  isVerified    Boolean  @default(false)
  totalEarnings Float    @default(0)
  totalSupport  Float    @default(0)
  totalViews    Int      @default(0)
  
  // Relations
  videos        Video[]
  supports      Support[]
}

model CreatorProfile {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty     String?
  experience    String?
  portfolio     String?
  rate          Float?
  rating        Float   @default(0)
  totalProjects Int     @default(0)
  totalEarnings Float   @default(0)
  pendingEarnings Float @default(0)
  isVerified    Boolean @default(false)
}

model AdminProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String?
  department  String?
}

// ─── VIDEO SYSTEM ─────────────────────────────────────────────────
model Video {
  id              Int         @id @default(autoincrement())
  title           String
  description     String?
  videoUrl        String
  thumbnail       String?
  
  // Ownership - ONLY Couples or Admin can upload
  coupleId        Int
  couple          CoupleProfile @relation(fields: [coupleId], references: [id])
  
  // Who uploaded the video (User reference)
  uploadedBy      Int
  uploader        User          @relation(fields: [uploadedBy], references: [id])
  
  // Access Control
  accessType      AccessType  @default(FREE)
  price           Float?
  supportAmount   Float?
  
  // Status
  status          VideoStatus @default(PENDING)
  isFeatured      Boolean     @default(false)
  views           Int         @default(0)
  likes           Int         @default(0)
  shares          Int         @default(0)
  
  // Earnings & Stats
  totalEarnings   Float       @default(0)
  totalPurchases  Int         @default(0)
  totalSupporters Int         @default(0)
  
  // Creator info
  creatorId       Int?
  creatorName     String?
  
  // Relations
  supports        Support[]
  purchases       VideoPurchase[]
  comments        Comment[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─── VIDEO PURCHASE ──────────────────────────────────────────────
model VideoPurchase {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  videoId         Int
  video           Video    @relation(fields: [videoId], references: [id])
  
  amount          Float
  purchaseType    String   // PURCHASE, SUPPORT
  expiresAt       DateTime?
  
  createdAt       DateTime @default(now())
  
  @@unique([userId, videoId])
}

// ─── BOOKING SYSTEM ──────────────────────────────────────────────
model Booking {
  id              Int         @id @default(autoincrement())
  bookingNumber   String      @unique
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  creatorId       Int?
  creator         User?       @relation("CreatorBookings", fields: [creatorId], references: [id])
  
  eventType       EventType
  eventDate       DateTime
  eventLocation   String
  district        String?
  guestCount      Int?
  budget          Float?
  package         String?
  notes           String?
  
  // Revenue split (90/10)
  totalAmount     Float?
  creatorEarnings Float?
  nyCommission    Float?
  creatorPaid     Boolean     @default(false)
  paidAt          DateTime?
  
  // Status
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─── SUPPORT SYSTEM ──────────────────────────────────────────────
model Support {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  coupleId       Int
  couple         CoupleProfile @relation(fields: [coupleId], references: [id])
  videoId        Int?
  video          Video?   @relation(fields: [videoId], references: [id])
  
  amount         Float
  coupleAmount   Float    // 60% goes to couple
  platformAmount Float    // 40% goes to platform
  
  message        String?
  status         SupportStatus @default(COMPLETED)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── PAYMENT SYSTEM ──────────────────────────────────────────────
model Payment {
  id            Int         @id @default(autoincrement())
  transactionId String      @unique
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  
  reference     String?
  receiptUrl    String?
  metadata      String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ─── POST SYSTEM ──────────────────────────────────────────────────
model Post {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  excerpt     String?
  coverImage  String?
  category    String
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  views       Int       @default(0)
  likes       Int       @default(0)
  shares      Int       @default(0)
  status      PostStatus @default(PUBLISHED)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  comments    Comment[]
}

// ─── COMMENT SYSTEM ──────────────────────────────────────────────
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id])
  videoId   Int?
  video     Video?   @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}

// ─── NOTIFICATION SYSTEM ──────────────────────────────────────────
model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  title     String?
  type      NotificationType
  isRead    Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  relatedId Int?
  link      String?
  createdAt DateTime @default(now())
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
  COUPLE
  CREATOR
}

enum EventType {
  WEDDING
  BIRTHDAY
  FUNERAL
  GRADUATION
  CORPORATE
  DOTE
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  CARD
  CASH
  BANK_TRANSFER
}

enum VideoStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum AccessType {
  FREE
  PREMIUM
  SUPPORT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SupportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum NotificationType {
  BOOKING
  PAYMENT
  SUPPORT
  VIDEO_APPROVED
  VIDEO_REJECTED
  PURCHASE
  SYSTEM
}